{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerReadWriteFPEKey",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:PutSecretValue"
      ],
      "Resource": "${fpe_secret_arn}"
    },
    {
      "Sid": "KMSDecryptGenerateDataKey",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "${kms_key_arn}"
    }
  ]
}
