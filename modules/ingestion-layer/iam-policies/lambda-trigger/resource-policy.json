{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SQSReadDelete",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "${sqs_queue_arn}"
    },
    {
      "Sid": "KMSDecryptSQSMessages",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "${kms_key_arn}"
    },
    {
      "Sid": "StartStepFunctions",
      "Effect": "Allow",
      "Action": [
        "states:StartExecution"
      ],
      "Resource": "${state_machine_arn}"
    }
  ]
}
